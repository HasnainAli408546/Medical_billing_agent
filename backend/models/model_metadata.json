{
  "model_type": "XGBoostClassifier",
  "target": "is_denied (1=Denied, 0=Not Denied)",
  "features": [
    "PatientGender_enc",
    "ProviderSpecialty_enc",
    "PatientMaritalStatus_enc",
    "PatientEmploymentStatus_enc",
    "ClaimType_enc",
